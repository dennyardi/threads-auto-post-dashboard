generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile         Profile?
  sessions        Session[]
  threadsAccounts ThreadsAccount[]
  posts           Post[]
  postMedia       PostMedia[]
  publishLogs     PublishLog[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash") @db.Char(64)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Profile {
  id        String   @id
  email     String?
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("profiles")
}

model ThreadsAccount {
  id                   String    @id @default(cuid())
  userId               String    @map("user_id")
  threadsUserId         String    @map("threads_user_id")
  username             String?
  displayName          String?   @map("display_name")
  profilePictureUrl    String?   @map("profile_picture_url") @db.Text
  accessTokenEncrypted String    @map("access_token_encrypted") @db.Text
  tokenType            String?   @map("token_type")
  expiresAt            DateTime? @map("expires_at")
  scopes               Json?
  isActive             Boolean   @default(true) @map("is_active")
  connectedAt          DateTime  @default(now()) @map("connected_at")
  disconnectedAt       DateTime? @map("disconnected_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts       Post[]
  publishLogs PublishLog[]

  @@unique([userId, threadsUserId])
  @@index([userId])
  @@index([threadsUserId])
  @@index([userId, isActive])
  @@map("threads_accounts")
}

model Post {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  threadsAccountId      String?   @map("threads_account_id")
  content               String    @db.Text
  mediaType             String    @default("NONE") @map("media_type")
  status                String    @default("draft")
  scheduledAt           DateTime? @map("scheduled_at")
  publishedAt           DateTime? @map("published_at")
  externalThreadsPostId String?   @map("external_threads_post_id")
  retryCount            Int       @default(0) @map("retry_count")
  errorMessage          String?   @map("error_message") @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  threadsAccount ThreadsAccount? @relation(fields: [threadsAccountId], references: [id], onDelete: SetNull)
  media          PostMedia[]
  publishLogs    PublishLog[]

  @@index([userId])
  @@index([threadsAccountId])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
  @@index([userId, status])
  @@map("posts")
}

model PostMedia {
  id          String   @id @default(cuid())
  postId      String   @map("post_id")
  userId      String   @map("user_id")
  storagePath String   @map("storage_path") @db.Text
  publicUrl   String?  @map("public_url") @db.Text
  mimeType    String?  @map("mime_type")
  sizeBytes   BigInt?  @map("size_bytes")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@map("post_media")
}

model PublishLog {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  threadsAccountId      String?  @map("threads_account_id")
  postId                String?  @map("post_id")
  status                String
  externalThreadsPostId String?  @map("external_threads_post_id")
  requestPayload        Json?    @map("request_payload")
  responsePayload       Json?    @map("response_payload")
  errorMessage          String?  @map("error_message") @db.Text
  createdAt             DateTime @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  threadsAccount ThreadsAccount? @relation(fields: [threadsAccountId], references: [id], onDelete: SetNull)
  post           Post?           @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([threadsAccountId])
  @@index([postId])
  @@index([status])
  @@index([createdAt])
  @@map("publish_logs")
}
